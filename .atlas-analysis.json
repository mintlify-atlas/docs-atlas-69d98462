  "keyFeatures": [
    "Single binary SQL stream processing engine",
    "Native Kafka and streaming platform integration",
    "Streaming ETL with multi-stream JOINs",
    "Tumble/hop/session windows with watermarks",
    "Materialized views for real-time aggregation",
    "ClickHouse-powered analytical queries",
    "External streams for Kafka, Redpanda, Pulsar",
    "External tables for ClickHouse, MySQL, PostgreSQL",
    "Python and JavaScript UDF support",
    "Sub-millisecond latency stream processing"
  ],
  "publicApiSurface": [
    "CREATE STREAM - Define streaming data structures",
    "CREATE EXTERNAL STREAM - Connect to Kafka/Pulsar",
    "CREATE MATERIALIZED VIEW - Real-time aggregations",
    "SELECT - Query streaming and historical data",
    "INSERT - Ingest data into streams",
    "tumble() - Tumbling window function",
    "hop() - Hopping window function",
    "session() - Session window function",
    "CREATE EXTERNAL TABLE - Connect to ClickHouse/databases",
    "CREATE RANDOM STREAM - Generate test data",
    "REST API /v1/queries - Execute streaming queries",
    "REST API /v1/ddl - DDL operations",
    "JDBC Driver - Java database connectivity",
    "Python SDK - proton-python-driver",
    "Go SDK - proton-go-driver"
  ]
